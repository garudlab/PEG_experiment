. /u/local/Modules/default/init/modules.sh

module load singularity

export MIDAS_DB=/u/project/ngarud/Garud_lab/metagenomic_fastq_files/PEG_experiment/midas_db/

OUTDIR=/u/project/ngarud/Garud_lab/metagenomic_fastq_files/PEG_experiment/midas_output/merged_midas_output
INDIR=/u/project/ngarud/Garud_lab/metagenomic_fastq_files/PEG_experiment/midas_output/midas_files

mkdir -p $OUTDIR/snps
mkdir -p $OUTDIR/genes

singularity exec $H2_CONTAINER_LOC/MIDAS-1.3.2.sif merge_midas.py snps $OUTDIR/snps -i $INDIR -t dir --sample_depth 5 --site_depth 3 --min_samples 1 --site_prev 0.0 --threads 5 > $OUTDIR/snps/species.log

singularity exec $H2_CONTAINER_LOC/MIDAS-1.3.2.sif merge_midas.py genes $OUTDIR/genes -i $INDIR -t dir --sample_depth 5 --min_samples 1 --cluster_pid 95 > $OUTDIR/genes/species.log






